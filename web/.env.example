# Supabase — salin file ini menjadi .env.local lalu isi nilainya.
# Ambil dari: Supabase Dashboard → Project Settings → API
#
# .env.local TIDAK di-commit (sudah diabaikan oleh .gitignore).
# Nilai ini aman dibuka ke browser (anon key dilindungi Row Level Security).

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
